						"          resultado = iif(instr(upper(toString(resultado)),'NOR')>0 || instr(upper(toString(resultado)),'NOM')>0 || instr(upper(toString(resultado)),'NRM')>0,'Normal',iif(instr(upper(toString(resultado)),'DESNUT')>0,'Desnutrición Leve',iif(instr(upper(toString(resultado)),'BAJO')>0 || instr(upper(toString(resultado)),'BAOJ')>0,'Bajo Peso',toString(null()))))) ~> limpieza",
						"limpieza sink(allowSchemaDrift: true,",
