{
	"name": "df_silver_sup_entregas",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "srcSupEntregas"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_sup_entregas",
						"type": "DatasetReference"
					},
					"name": "sinkSupEntregas"
				}
			],
			"transformations": [
				{
					"name": "limpieza"
				}
			],
			"scriptLines": [
				"source(output(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          paquete_nombre as string,",
				"          fecha_entrega as string,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as double,",
				"          fecha_proxima_entrega as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    entrega_id,\\n    boleta_id,\\n    REPLACE(REPLACE(TRIM(ci_beneficiaria),\\'\"\\',\\'\\'),\\' \\',\\'\\') AS ci_beneficiaria,\\n    establecimiento_id,\\n    paquete_id,\\n    REPLACE(TRIM(paquete_nombre),\\'\"\\',\\'\\') AS paquete_nombre,\\n    REPLACE(TRIM(fecha_entrega),\\'\"\\',\\'\\') AS fecha_entrega,\\n    REPLACE(TRIM(lote_produccion),\\'\"\\',\\'\\') AS lote_produccion,\\n    peso_paquete_kg,\\n    REPLACE(TRIM(fecha_proxima_entrega),\\'\"\\',\\'\\') AS fecha_proxima_entrega\\nFROM bronze.sup_entregas\\nWHERE entrega_id IS NOT NULL',",
				"     format: 'query') ~> srcSupEntregas",
				"srcSupEntregas derive(ci_beneficiaria = upper(regexReplace(replace(replace(toString(ci_beneficiaria),'-',''),' ',''),'^([A-Za-z]{2})([0-9]+)$','$2$1')),",
				"          fecha_entrega = coalesce(toDate(toString(fecha_entrega),'yyyy-MM-dd'),toDate(toString(fecha_entrega),'dd-MM-yyyy'),toDate(toString(fecha_entrega),'dd/MM/yyyy'),toDate(toString(fecha_entrega),'MM/dd/yyyy')),",
				"          fecha_proxima_entrega = coalesce(toDate(toString(fecha_proxima_entrega),'yyyy-MM-dd'),toDate(toString(fecha_proxima_entrega),'dd-MM-yyyy'),toDate(toString(fecha_proxima_entrega),'dd/MM/yyyy'),toDate(toString(fecha_proxima_entrega),'MM/dd/yyyy')),",
				"          peso_paquete_kg = round(toFloat(peso_paquete_kg),2)) ~> limpieza",
				"limpieza sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          entrega_id as integer,",
				"          boleta_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          paquete_id as integer,",
				"          paquete_nombre as string,",
				"          fecha_entrega as date,",
				"          lote_produccion as string,",
				"          peso_paquete_kg as double,",
				"          fecha_proxima_entrega as date",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError') ~> sinkSupEntregas"
			]
		}
	}
}