{
	"name": "DF_Gold_Dim_Paquete",
	"properties": {
		"folder": {
			"name": "gold"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "silver_sup_catalogopaquetes",
						"type": "DatasetReference"
					},
					"name": "srcsupcatalogopaquetes"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "ds_gold_dim_paquete",
						"type": "DatasetReference"
					},
					"name": "goldimpaquete"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as decimal(5,2),",
				"          costo_estimado_bs as integer",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     format: 'table') ~> srcsupcatalogopaquetes",
				"srcsupcatalogopaquetes sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          paquete_id as integer,",
				"          nombre as string,",
				"          contenido as string,",
				"          peso_estandar_kg as double,",
				"          costo_estimado_bs as integer",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          nombre,",
				"          contenido,",
				"          peso_estandar_kg,",
				"          costo_estimado_bs",
				"     )) ~> goldimpaquete"
			]
		}
	}
}