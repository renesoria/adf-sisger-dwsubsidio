{
	"name": "df_silver_bja_controles_prenatales",
	"properties": {
		"folder": {
			"name": "silver"
		},
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "bronze_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "srcBjaControlesPrenatales"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "silver_bja_controles_prenatales",
						"type": "DatasetReference"
					},
					"name": "sinkBJAcontrolesPrenatales"
				}
			],
			"transformations": [
				{
					"name": "limpieza"
				}
			],
			"scriptLines": [
				"source(output(",
				"          control_prenatal_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as string,",
				"          semana_gestacion as double,",
				"          peso_madre_kg as double,",
				"          presion_arterial as string,",
				"          resultado as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     isolationLevel: 'READ_UNCOMMITTED',",
				"     query: 'SELECT\\n    control_prenatal_id,\\n    TRIM(ci_beneficiaria) AS ci_beneficiaria,\\n    establecimiento_id,\\n    nro_control,\\n    TRIM(fecha_control) AS fecha_control,\\n    semana_gestacion,\\n    peso_madre_kg,\\n    TRIM(presion_arterial) AS presion_arterial,\\n    TRIM(resultado) AS resultado\\nFROM bronze.bja_controles_prenatales\\nWHERE control_prenatal_id IS NOT NULL',",
				"     format: 'query') ~> srcBjaControlesPrenatales",
				"srcBjaControlesPrenatales derive(ci_beneficiaria = regexReplace(replace(replace(toString(ci_beneficiaria),'-',''),' ',''),'^([A-Z]{2})([0-9]+)$','$2$1'),",
				"          fecha_control = coalesce(toDate(toString(fecha_control),'yyyy-MM-dd'),toDate(toString(fecha_control),'dd-MM-yyyy'),toDate(toString(fecha_control),'dd/MM/yyyy'),toDate(toString(fecha_control),'MM/dd/yyyy')),",
				"          peso_madre_kg = case(toFloat(peso_madre_kg)>=35.0 && toFloat(peso_madre_kg)<=200.0, round(toFloat(peso_madre_kg),1))\r",
				",",
				"          resultado = iif(instr(upper(toString(resultado)),'NOM')>0 || instr(upper(toString(resultado)),'NOR')>0 || instr(upper(toString(resultado)),'NRM')>0,'Normal',iif(instr(upper(toString(resultado)),'ALT')>0 || instr(upper(toString(resultado)),'LTO')>0,'Riesgo Alto',iif(instr(upper(toString(resultado)),'MODER')>0 || instr(upper(toString(resultado)),'ODER')>0,'Riesgo Moderado',iif(instr(upper(toString(resultado)),'BAJO')>0,'Riesgo Bajo',toString(null()))))),",
				"          presion_sistolica = toInteger(trim(split(toString(presion_arterial),'/')[1])),",
				"          presion_diastolica = toInteger(trim(split(toString(presion_arterial),'/')[2]))) ~> limpieza",
				"limpieza sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     input(",
				"          control_prenatal_id as integer,",
				"          ci_beneficiaria as string,",
				"          establecimiento_id as integer,",
				"          nro_control as integer,",
				"          fecha_control as date,",
				"          semana_gestacion as double,",
				"          peso_madre_kg as decimal(5,1),",
				"          presion_sistolica as integer,",
				"          presion_diastolica as integer,",
				"          resultado as string",
				"     ),",
				"     deletable:false,",
				"     insertable:true,",
				"     updateable:false,",
				"     upsertable:false,",
				"     format: 'table',",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true,",
				"     errorHandlingOption: 'stopOnFirstError',",
				"     mapColumn(",
				"          control_prenatal_id,",
				"          ci_beneficiaria,",
				"          establecimiento_id,",
				"          nro_control,",
				"          fecha_control,",
				"          semana_gestacion,",
				"          peso_madre_kg,",
				"          presion_sistolica,",
				"          presion_diastolica,",
				"          resultado",
				"     )) ~> sinkBJAcontrolesPrenatales"
			]
		}
	}
}